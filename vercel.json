{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "rewrites": [
    {
      "source": "/",
      "destination": "/api/index.php"
    },
    {
      "source": "/index.php",
      "destination": "/api/index.php"
    },
    {
      "source": "/about.php",
      "destination": "/api/about.php"
    },
    {
      "source": "/contact.php",
      "destination": "/api/contact.php"
    },
    {
      "source": "/events.php",
      "destination": "/api/events.php"
    },
    {
      "source": "/booking.php",
      "destination": "/api/booking.php"
    },
    {
      "source": "/process_booking.php",
      "destination": "/api/process_booking.php"
    },
    {
      "source": "/login.php",
      "destination": "/api/login.php"
    },
    {
      "source": "/logout.php",
      "destination": "/api/logout.php"
    },
    {
      "source": "/admin_panel.php",
      "destination": "/api/admin_panel.php"
    },
    {
      "source": "/update_status.php",
      "destination": "/api/update_status.php"
    },
    {
      "source": "/delete_booking.php",
      "destination": "/api/delete_booking.php"
    },
    {
      "source": "/upload.php",
      "destination": "/api/upload.php"
    },
    {
      "source": "/fetch_events.php",
      "destination": "/api/fetch_events.php"
    },
    {
      "source": "/admin.php",
      "destination": "/api/admin.php"
    }
  ]
}
